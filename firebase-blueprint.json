{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the logistics system (admin, agente, influencer, partner, or cliente).",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agente", "influencer", "partner", "cliente"] },
        "telefono": { "type": "string" },
        "dni": { "type": "string" },
        "direccion": { "type": "string" },
        "oficina": { "type": "string" },
        "socialHandle": { "type": "string" },
        "businessName": { "type": "string" },
        "precioPorKilo": { "type": "number" },
        "notas": { "type": "string" },
        "balance": { "type": "number" },
        "tipoColaborador": { "type": "string", "enum": ["agente_freelance", "influencer", "empresa_b2b", "punto_pack", "none"] },
        "codigoReferido": { "type": "string" },
        "tier": { "type": "string", "enum": ["bronze", "silver", "gold", "elite"] },
        "tasaComision": { "type": "number" },
        "balanceComisiones": { "type": "number" },
        "payoutMethod": { "type": "string" },
        "payoutDetails": { "type": "string" },
        "apiKey": { "type": "string" },
        "capacityPackages": { "type": "number" },
        "contractUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Referral": {
      "title": "Referral",
      "description": "A referral tracking record for influencers.",
      "type": "object",
      "properties": {
        "influencerId": { "type": "string" },
        "visitorId": { "type": "string" },
        "source": { "type": "string" },
        "converted": { "type": "boolean" },
        "convertedUserId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["influencerId", "timestamp"]
    },
    "B2BInvoice": {
      "title": "B2BInvoice",
      "description": "A monthly invoice for B2B partners.",
      "type": "object",
      "properties": {
        "partnerId": { "type": "string" },
        "monto": { "type": "number" },
        "estado": { "type": "string", "enum": ["Pendiente", "Pagado", "Vencido"] },
        "fechaEmision": { "type": "string", "format": "date-time" },
        "fechaVencimiento": { "type": "string", "format": "date-time" },
        "pdfUrl": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "tracking": { "type": "string" },
              "peso": { "type": "number" },
              "precio": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          } 
        }
      },
      "required": ["partnerId", "monto", "estado", "fechaEmision"]
    },
    "Pago": {
      "title": "Pago",
      "description": "A payment record for a package.",
      "type": "object",
      "properties": {
        "paqueteId": { "type": "string" },
        "monto": { "type": "number" },
        "metodo": { "type": "string", "enum": ["Efectivo", "Transferencia", "Tarjeta"] },
        "estado": { "type": "string", "enum": ["Pagado", "Pendiente", "Confirmado"] },
        "fecha": { "type": "string", "format": "date-time" },
        "agenteId": { "type": "string" },
        "confirmadoPor": { "type": "string" },
        "fechaConfirmacion": { "type": "string", "format": "date-time" }
      },
      "required": ["paqueteId", "monto", "metodo", "fecha", "agenteId"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "globalWholesalePrice": { "type": "number" }
      }
    }
,
    "Paquete": {
      "title": "Paquete",
      "description": "A package being shipped.",
      "type": "object",
      "properties": {
        "tracking": { "type": "string" },
        "clienteNombre": { "type": "string" },
        "clienteTelefono": { "type": "string" },
        "peso": { "type": "number" },
        "origen": { "type": "string" },
        "destino": { "type": "string" },
        "contenido": { "type": "string" },
        "estado": { "type": "string", "enum": ["Recepción", "Validación", "Consolidado", "Despacho", "Incidencia", "Entregado", "Pendiente"] },
        "referidoPor": { "type": "string" },
        "montoComision": { "type": "number" },
        "partnerId": { "type": "string" },
        "precioAplicado": { "type": "number" },
        "esB2B": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "operadorId": { "type": "string" }
      },
      "required": ["tracking", "peso", "origen", "destino", "estado", "createdAt"]
    },
    "Evento": {
      "title": "Evento",
      "description": "A timeline event for a package.",
      "type": "object",
      "properties": {
        "paqueteId": { "type": "string" },
        "estado": { "type": "string" },
        "notas": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "operadorId": { "type": "string" }
      },
      "required": ["paqueteId", "estado", "timestamp"]
    },
    "Cliente": {
      "title": "Cliente",
      "description": "A customer who sends packages.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "telefono": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "telefono"]
    },
    "Noticia": {
      "title": "Noticia",
      "description": "A news article.",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "contenido": { "type": "string" },
        "imagenUrl": { "type": "string" },
        "fuente": { "type": "string" },
        "fuenteUrl": { "type": "string" },
        "categoria": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["titulo", "contenido", "createdAt"]
    },
    "SolicitudAfiliado": {
      "title": "SolicitudAfiliado",
      "description": "An application to become an affiliate (agent or influencer).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["agente", "influencer"] },
        "nombre": { "type": "string" },
        "telefono": { "type": "string" },
        "ciudad": { "type": "string" },
        "zonaCobertura": { "type": "string" },
        "experiencia": { "type": "string" },
        "redesSociales": { "type": "string" },
        "seguidores": { "type": "string" },
        "enfoqueComunidad": { "type": "string" },
        "referidor": { "type": "string" },
        "status": { "type": "string", "enum": ["pendiente", "aprobado", "rechazado"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "nombre", "telefono", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users of the system."
    },
    "/paquetes/{paqueteId}": {
      "schema": { "$ref": "#/entities/Paquete" },
      "description": "Packages in the system."
    },
    "/eventos/{eventoId}": {
      "schema": { "$ref": "#/entities/Evento" },
      "description": "Timeline events for packages."
    },
    "/clientes/{clienteId}": {
      "schema": { "$ref": "#/entities/Cliente" },
      "description": "Customers."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Global settings."
    },
    "/noticias/{noticiaId}": {
      "schema": { "$ref": "#/entities/Noticia" },
      "description": "News articles."
    },
    "/referrals/{referralId}": {
      "schema": { "$ref": "#/entities/Referral" },
      "description": "Referral tracking."
    },
    "/b2b_invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/B2BInvoice" },
      "description": "B2B Partner invoices."
    },
    "/solicitudesAfiliado/{solicitudId}": {
      "schema": { "$ref": "#/entities/SolicitudAfiliado" },
      "description": "Affiliate applications."
    }
  }
}
